<%#
# Navigation

This partial is used to display the navigation in Administrate.
By default, the navigation contains navigation links
for all resources in the admin dashboard,
as defined by the routes in the `admin/` namespace
%>

<%= vite_client_tag %>
<%= vite_javascript_tag 'superadmin_pages' %>

<%
  sidebar_icons = {
    accounts: 'icon-building-4-line',
    users: 'icon-user-follow-line',
    platform_apps: 'icon-apps-2-line',
    agent_bots: 'icon-robot-line',
    platform_banners: 'icon-megaphone-line',
  }
%>

<div class="border-slate-100 border-r w-56 flex-shrink-0 justify-between h-full flex flex-col" role="navigation">
  <div>
    <div class="flex mx-4 mb-4 border-slate-100 border-b py-6">
      <%= link_to image_tag('/brand-assets/logo_thumbnail.svg', alt: t('super_admin.navigation.logo_alt'), class: 'h-10'), super_admin_root_url %>
      <div class="flex flex-col ml-3">
        <div class="text-sm">ViperChat <%= Chatwoot.config[:version] %></div>
        <div class="text-xs text-slate-700 mt-0.5"><%= t('super_admin.navigation.console') %></div>
      </div>
    </div>

    <ul class="my-4">
      <%= render partial: "nav_item", locals: { icon: 'icon-grid-line', url: super_admin_root_url, label: t('super_admin.navigation.dashboard') } %>
      <%= render partial: "nav_item", locals: { icon: 'icon-settings-2-line', url: super_admin_installation_configs_url, label: t('super_admin.navigation.installation_configs') } %>
      <% Administrate::Namespace.new(namespace).resources.each do |resource| %>
        <% next if ["account_users", "access_tokens", "installation_configs", "dashboard", "devise/sessions", "app_configs", "instance_statuses", "settings", "push_diagnostics"].include?  resource.resource %>
        <% next if resource.resource == "platform_banners" && !ChatwootApp.chatwoot_cloud? %>
        <% resource_label = t("administrate.resources.#{resource.resource}.name", default: display_resource_name(resource)) %>
        <%= render partial: "nav_item", locals: {
            icon: sidebar_icons[resource.resource.to_sym],
            url: resource_index_route(resource),
            label: resource_label,
          }
        %>

      <% end %>
      <%= render 'settings_menu', open: settings_open? %>
    </ul>
  </div>
  <div>
    <ul class="my-4">
      <%= render partial: "nav_item", locals: { icon: 'icon-mist-fill', url: sidekiq_web_url, label: t('super_admin.navigation.sidekiq_dashboard') } %>
      <%= render partial: "nav_item", locals: { icon: 'icon-health-book-line', url: super_admin_instance_status_url, label: t('super_admin.navigation.instance_health') } %>
      <%= render partial: "nav_item", locals: { icon: 'icon-mail-send-fill', url: super_admin_push_diagnostics_url, label: t('super_admin.navigation.push_diagnostics') } %>
      <%= render partial: "nav_item", locals: { icon: 'icon-dashboard-line', url: '/', label: t('super_admin.navigation.agent_dashboard') } %>
      <%= render partial: "nav_item", locals: { icon: 'icon-logout-circle-r-line', url: super_admin_logout_url, label: t('super_admin.navigation.logout') } %>
    </ul>
  </div>
</div>
